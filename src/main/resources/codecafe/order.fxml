<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<StackPane fx:id="orderCard" prefHeight="253.0" prefWidth="276.0" styleClass="order" stylesheets="@order.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="codecafe.AdminControllers.OrderCardController">
   <children>
      <VBox maxHeight="290.0" minHeight="290.0" prefHeight="250.0">
         <children>
            <HBox prefHeight="56.0" prefWidth="387.0">
               <children>
                  <Label text="ORDER">
                     <font>
                        <Font size="18.0" />
                     </font>
                     <HBox.margin>
                        <Insets left="20.0" top="10.0" />
                     </HBox.margin>
                  </Label>
                  <Label fx:id="order_NUMBER" text="#00001">
                     <HBox.margin>
                        <Insets left="10.0" top="10.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <Separator prefWidth="200.0" stylesheets="@../codecafe/order.css" />
            <StackPane prefHeight="47.0" prefWidth="387.0">
               <children>
                  <Label fx:id="dineIn_takeOut" text="DINE-IN">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
               </children>
            </StackPane>
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="invisible-scroll" stylesheets="@order.css" VBox.vgrow="ALWAYS">
               <VBox.margin>
                  <Insets left="20.0" />
               </VBox.margin>
               <content>
                  <VBox fx:id="itemsContainer" alignment="TOP_LEFT" prefHeight="204.0" prefWidth="367.0" stylesheets="@order.css">
                     <children>
                        <HBox spacing="5" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
            <StackPane prefHeight="61.0" prefWidth="387.0">
               <children>
                  <Button fx:id="complete_order" maxHeight="30.0" mnemonicParsing="false" onAction="#completeOrder" prefHeight="30.0" prefWidth="142.0" styleClass="complete-order-btn" stylesheets="@../codecafe/order.css" text="Complete order">
                     <StackPane.margin>
                        <Insets bottom="5.0" />
                     </StackPane.margin>
                  </Button>
               </children>
            </StackPane>
         </children>
      </VBox>
   </children>
</StackPane>
